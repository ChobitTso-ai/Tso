# Copy to .env and fill in your values

ANTHROPIC_API_KEY=sk-ant-...

# MCP Server
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_BASE_URL=http://localhost:8000

# Vault encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
VAULT_ENCRYPTION_KEY=

# OAuth / CIMD
OAUTH_CLIENT_ID=agent-mcp-client
OAUTH_CLIENT_NAME=Agent MCP Client

# Optional
CLAUDE_MODEL=claude-sonnet-4-6
MAX_TOKENS=4096
AGENT_VAULT_ID=
